# ============================================================
# Variables de entorno del BFF
# Copia este archivo como .env y ajusta las URLs según tu entorno.
# ============================================================

# URLs de los microservicios internos
# En Docker Compose se usan los nombres de los servicios, no localhost
PLACE_SERVICE_URL=http://place-service:8002
AUTH_SERVICE_URL=http://auth-service:8001
ASSISTANT_SERVICE_URL=http://assistant-service:8008

# Para desarrollo local:
# PLACE_SERVICE_URL=http://localhost:8002
# AUTH_SERVICE_URL=http://localhost:8001
# ASSISTANT_SERVICE_URL=http://localhost:8008
